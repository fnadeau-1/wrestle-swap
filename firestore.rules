rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Products collection
    match /products/{productId} {
      // Anyone can read products
      allow read: if true;
      // Any signed-in user can create a product
      allow create: if request.auth != null;
      // Only the owner can update or delete their own product.
      // sold/cancelled status is set by Cloud Functions via Admin SDK (bypasses rules).
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Users collection
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Usernames collection (for username uniqueness)
    match /usernames/{username} {
      allow read: if true;
      // Only the user whose ID matches the document's userId field can write
      allow write: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // Orders collection
    match /orders/{orderId} {
      // Only the buyer or seller can read their own order
      allow read: if request.auth != null && (
        resource.data.buyerId == request.auth.uid ||
        resource.data.sellerId == request.auth.uid
      );
      // Only the buyer can create an order for themselves
      allow create: if request.auth != null && request.resource.data.buyerId == request.auth.uid;
      // Only the buyer or seller can update their order
      allow update: if request.auth != null && (
        resource.data.buyerId == request.auth.uid ||
        resource.data.sellerId == request.auth.uid
      );
    }

    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
