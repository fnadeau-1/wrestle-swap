rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is the requesting user an admin?
    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true;
    }

    // -------------------------------------------------------------------------
    // Products collection
    // -------------------------------------------------------------------------
    match /products/{productId} {
      allow read: if true;

      // Seller must be authenticated, email-verified, not suspended, and must own the listing.
      // Field-level validation prevents price manipulation and oversized payloads.
      allow create: if request.auth != null
        && request.auth.token.email_verified == true
        && request.resource.data.userId == request.auth.uid
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('sellerSuspended', false) == false
        // Price: must be a positive number ≤ $10,000
        && request.resource.data.price is number
        && request.resource.data.price > 0
        && request.resource.data.price <= 10000
        // Title: non-empty string, max 200 chars
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 200
        // Category: must be a string
        && request.resource.data.category is string
        && request.resource.data.category.size() > 0
        // Block clients from writing sensitive/internal fields
        && !request.resource.data.keys().hasAny([
            'sellerEmail', 'sold', 'cancelled', 'buyerId', 'soldOrderId',
            'shipped', 'delivered', 'sellerPaidOut', 'sellerStripeAccountId',
            'sellerReceivesCents', 'payoutInitiated'
        ]);

      allow update: if isAdmin()
        // Seller can edit their own UNSOLD listing — never touch order/payout/fulfillment/status fields
        || (request.auth != null
            && resource.data.userId == request.auth.uid
            && resource.data.sold != true
            && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
                'sold', 'cancelled',
                'buyerId', 'soldOrderId', 'soldAt', 'soldTimestamp',
                'cancelledAt', 'cancelledBy', 'refundId', 'cancelInitiated',
                'trackingNumber', 'trackingUrl', 'carrier', 'shipped', 'shippedAt',
                'delivered', 'deliveredAt', 'shippingCost',
                'sellerPaidOut', 'sellerPaidOutAt', 'sellerPayoutTransferId',
                'payoutInitiated', 'autoReleaseBlocked', 'autoReleaseWarned',
                'autoReleaseWarningAt', 'autoReleaseWarningTimestamp',
                'autoReleasedAt', 'autoReleaseCompleted',
                'review', 'sellerRating'
            ]))
        // Buyer can leave a review on a delivered order they purchased.
        // ordersDocId must be included in the update so we can verify via the orders collection
        // (buyerId is not stored on product docs for privacy — it lives only in orders).
        || (request.auth != null
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                'review', 'sellerRating', 'updatedAt', 'ordersDocId'
            ])
            && request.resource.data.get('ordersDocId', '') != ''
            && get(/databases/$(database)/documents/orders/$(request.resource.data.ordersDocId)).data.buyerId == request.auth.uid
            && get(/databases/$(database)/documents/orders/$(request.resource.data.ordersDocId)).data.productId == productId
            && get(/databases/$(database)/documents/orders/$(request.resource.data.ordersDocId)).data.delivered == true
            && get(/databases/$(database)/documents/orders/$(request.resource.data.ordersDocId)).data.get('cancelled', false) != true)
        // Buyer can flag a refund request or dispute on an active (sold, not cancelled, not yet delivered) order.
        // ordersDocId must be included in the update — buyerId not stored on product docs.
        || (request.auth != null
            && resource.data.sold == true
            && resource.data.cancelled != true
            && resource.data.delivered != true
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                'refundRequested', 'refundRequestedAt', 'refundReason',
                'disputeOpened', 'updatedAt', 'ordersDocId'
            ])
            && request.resource.data.get('ordersDocId', '') != ''
            && get(/databases/$(database)/documents/orders/$(request.resource.data.ordersDocId)).data.buyerId == request.auth.uid
            && get(/databases/$(database)/documents/orders/$(request.resource.data.ordersDocId)).data.productId == productId);

      // Sellers can delete their own unsold listings; sold/active listings are locked
      allow delete: if isAdmin()
        || (request.auth != null
            && resource.data.userId == request.auth.uid
            && resource.data.sold != true);
    }

    // -------------------------------------------------------------------------
    // Users collection
    // -------------------------------------------------------------------------
    match /users/{userId} {
      // Owner + admins get full read. Public profile data is served via the
      // getPublicProfile Cloud Function to avoid leaking sensitive fields
      // (stripeAccountId, isAdmin, sellerStrikes, etc.) to other users.
      allow read: if isAdmin()
        || (request.auth != null && request.auth.uid == userId);

      // New users create their own profile; privilege/suspension fields are blocked at creation
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.get('isAdmin', false) == false
        && request.resource.data.get('sellerSuspended', false) == false
        && request.resource.data.get('sellerCancellationCount', 0) == 0;

      // Admins can update anything; regular users can update their own doc but cannot
      // touch privilege, suspension, penalty, or Stripe identity fields
      allow update: if isAdmin()
        || (request.auth != null
          && request.auth.uid == userId
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
              'sellerSuspended', 'sellerCancellationCount', 'sellerPenalties', 'isAdmin',
              'stripeAccountId', 'stripeCreatedAt', 'stripePayoutsEnabled'
          ])
          // displayName must always equal username — no real-name leakage
          && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['displayName', 'username'])
              || request.resource.data.get('displayName', '') == request.resource.data.get('username', ''))
          // Field length limits — only validate fields that are actually being changed
          && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['bio'])
              || (request.resource.data.bio is string && request.resource.data.bio.size() <= 500))
          && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['location'])
              || (request.resource.data.location is string && request.resource.data.location.size() <= 200))
          && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['username'])
              || (request.resource.data.username is string
                  && request.resource.data.username.size() >= 3
                  && request.resource.data.username.size() <= 30
                  && request.resource.data.username.matches('^[a-z0-9_]+$'))));

      allow delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // Usernames collection (uniqueness reservation)
    // -------------------------------------------------------------------------
    match /usernames/{username} {
      allow read: if true;
      // Create: only if no document exists, username is 3–30 lowercase alphanumeric/underscore chars
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && !exists(/databases/$(database)/documents/usernames/$(username))
        && username.size() >= 3
        && username.size() <= 30
        && username.matches('^[a-z0-9_]+$');
      // Update: only the current owner can change their own reservation
      allow update: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && resource.data.userId == request.auth.uid;
      // Delete: only the owner can release their username
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // -------------------------------------------------------------------------
    // Orders collection
    // All mutations handled exclusively by Cloud Functions via Admin SDK
    // -------------------------------------------------------------------------
    match /orders/{orderId} {
      allow read: if isAdmin()
        || (request.auth != null && (
          resource.data.buyerId == request.auth.uid ||
          resource.data.sellerId == request.auth.uid
        ));
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // Conversations + messages (messaging)
    // -------------------------------------------------------------------------
    match /conversations/{conversationId} {
      allow read: if isAdmin()
        || (request.auth != null && request.auth.uid in resource.data.participants);

      // Buyer initiates conversation; must include exactly 2 participants
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.size() == 2
        && request.resource.data.buyerId == request.auth.uid;

      // Participants can only update messaging metadata — never structural fields
      allow update: if request.auth != null
        && request.auth.uid in resource.data.participants
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'lastMessage', 'lastMessageAt', 'lastSenderId',
            'unreadBuyer', 'unreadSeller', 'deletedBy'
        ]);

      match /messages/{messageId} {
        allow read: if isAdmin()
          || (request.auth != null
            && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants);
        // Create only — editing or deleting existing messages is not permitted
        // Rate-limited: 1 message per second per conversation (anti-spam).
        // Repeated get() calls to the same path are cached within a single rule evaluation.
        allow create: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants
          && (get(/databases/$(database)/documents/conversations/$(conversationId)).data.get('lastMessageAt', null) == null
              || request.time > get(/databases/$(database)/documents/conversations/$(conversationId)).data.lastMessageAt + duration.value(1, 's'));
      }
    }

    // -------------------------------------------------------------------------
    // Watchlists — owner only
    // -------------------------------------------------------------------------
    match /watchlists/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // -------------------------------------------------------------------------
    // Seller ratings
    // -------------------------------------------------------------------------
    match /sellerRatings/{ratingId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.buyerId
        && ratingId == request.resource.data.orderId + '_' + request.auth.uid
        // ordersDocId must be included — buyerId is not stored on products, only in orders
        && request.resource.data.get('ordersDocId', '') != ''
        && get(/databases/$(database)/documents/orders/$(request.resource.data.ordersDocId)).data.buyerId == request.auth.uid
        && get(/databases/$(database)/documents/orders/$(request.resource.data.ordersDocId)).data.productId == request.resource.data.orderId
        && get(/databases/$(database)/documents/orders/$(request.resource.data.ordersDocId)).data.delivered == true
        // Rating must be a whole number between 1 and 5
        && request.resource.data.get('rating', 0) >= 1
        && request.resource.data.get('rating', 0) <= 5;
      allow update, delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // Community reports — anyone can file; only admins can read/manage
    // -------------------------------------------------------------------------
    match /reports/{reportId} {
      allow create: if request.auth != null;
      allow read, update, delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // Refund requests
    // -------------------------------------------------------------------------
    match /refundRequests/{requestId} {
      allow create: if request.auth != null
        && request.resource.data.buyerId == request.auth.uid
        && request.resource.data.get('ordersDocId', '') != ''
        && get(/databases/$(database)/documents/orders/$(request.resource.data.ordersDocId)).data.buyerId == request.auth.uid
        && get(/databases/$(database)/documents/orders/$(request.resource.data.ordersDocId)).data.productId == request.resource.data.productId
        && get(/databases/$(database)/documents/orders/$(request.resource.data.ordersDocId)).data.get('cancelled', false) != true;
      allow read: if isAdmin()
        || (request.auth != null && (
          resource.data.buyerId == request.auth.uid ||
          resource.data.sellerId == request.auth.uid
        ));
      allow update: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // Platform config (announcements, site settings)
    // -------------------------------------------------------------------------
    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // In-app notifications — recipient can read; Cloud Functions write via Admin SDK
    // -------------------------------------------------------------------------
    match /notifications/{userId}/items/{notifId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      // Users can only mark their own notifications as read
      allow update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create, delete: if false;
    }

    // -------------------------------------------------------------------------
    // Disputes
    // -------------------------------------------------------------------------
    match /disputes/{disputeId} {
      allow create: if request.auth != null
        && request.resource.data.buyerId == request.auth.uid
        && request.resource.data.get('ordersDocId', '') != ''
        && get(/databases/$(database)/documents/orders/$(request.resource.data.ordersDocId)).data.buyerId == request.auth.uid
        && get(/databases/$(database)/documents/orders/$(request.resource.data.ordersDocId)).data.productId == request.resource.data.productId
        && get(/databases/$(database)/documents/orders/$(request.resource.data.ordersDocId)).data.get('cancelled', false) != true;
      allow read: if isAdmin()
        || (request.auth != null && (
          resource.data.buyerId == request.auth.uid ||
          resource.data.sellerId == request.auth.uid
        ));
      allow update, delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // Abandoned carts — written exclusively by Cloud Functions via Admin SDK
    // -------------------------------------------------------------------------
    match /abandonedCarts/{docId} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // Rate limit counters — written exclusively by Cloud Functions via Admin SDK
    // -------------------------------------------------------------------------
    match /rateLimits/{userId} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // Default deny for all other collections
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
