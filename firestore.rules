rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is the requesting user an admin?
    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true;
    }

    // Products collection
    match /products/{productId} {
      allow read: if true;
      allow create: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('sellerSuspended', false) == false;
      allow update: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAdmin()
        || (request.auth != null && request.auth.uid == userId)
        || resource.data.keys().hasOnly(['displayName', 'username', 'photoURL', 'createdAt', 'email']);
      // Admins can write anything (unsuspend sellers, etc.)
      // Regular users can write their own doc but cannot touch penalty/suspension fields
      allow write: if isAdmin()
        || (request.auth != null
          && request.auth.uid == userId
          && !('sellerSuspended' in request.resource.data.diff(resource.data).affectedKeys())
          && !('sellerCancellationCount' in request.resource.data.diff(resource.data).affectedKeys())
          && !('sellerPenalties' in request.resource.data.diff(resource.data).affectedKeys())
          && !('isAdmin' in request.resource.data.diff(resource.data).affectedKeys()));
    }

    // Usernames collection (for username uniqueness)
    match /usernames/{username} {
      allow read: if true;
      // Only the user whose ID matches the document's userId field can write
      allow write: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // Orders collection
    match /orders/{orderId} {
      // Admins can read/write any order; buyers and sellers can access their own
      allow read: if isAdmin() || (request.auth != null && (
        resource.data.buyerId == request.auth.uid ||
        resource.data.sellerId == request.auth.uid
      ));
      // Only the buyer can create an order for themselves
      allow create: if request.auth != null && request.resource.data.buyerId == request.auth.uid;
      // Admins or buyer/seller can update their order
      allow update: if isAdmin() || (request.auth != null && (
        resource.data.buyerId == request.auth.uid ||
        resource.data.sellerId == request.auth.uid
      ));
      allow delete: if isAdmin();
    }

    // Conversations collection (messaging)
    // participants array contains [buyerId, sellerId] — enables array-contains queries
    match /conversations/{conversationId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.buyerId == request.auth.uid;
      allow update: if request.auth != null
        && request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
      }
    }

    // Watchlists — only owner can read/write
    match /watchlists/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Seller ratings — anyone can read, authenticated users can create once per seller,
    // only admins can delete/flag reviews
    match /sellerRatings/{ratingId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // Community reports — authenticated users can file a report,
    // only admins can read or manage reports
    match /reports/{reportId} {
      allow create: if request.auth != null;
      allow read, update, delete: if isAdmin();
    }

    // Refund requests — buyers can create, buyer or seller can read their own,
    // admins can read and update all
    match /refundRequests/{requestId} {
      allow create: if request.auth != null;
      allow read: if isAdmin()
        || (request.auth != null && (
          resource.data.buyerId == request.auth.uid ||
          resource.data.sellerId == request.auth.uid
        ));
      allow update: if isAdmin();
    }

    // Platform config (announcements, site settings) — anyone can read,
    // only admins can write
    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
