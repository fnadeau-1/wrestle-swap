rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is the requesting user an admin?
    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true;
    }

    // Products collection
    match /products/{productId} {
      allow read: if true;
      // Seller must be authenticated, email-verified, not suspended, and must own the listing
      allow create: if request.auth != null
        && request.auth.token.email_verified == true
        && request.resource.data.userId == request.auth.uid
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('sellerSuspended', false) == false;
      // Sellers can edit their own listings but cannot touch order/payment/fulfilment fields
      // (those are written exclusively by Cloud Functions via Admin SDK which bypasses rules)
      allow update: if isAdmin()
        // Seller can update their own listing — but never touch order/payout/escrow fields
        || (request.auth != null
            && resource.data.userId == request.auth.uid
            && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
                'sold', 'buyerId', 'soldOrderId', 'soldAt', 'soldTimestamp',
                'cancelledAt', 'cancelledBy', 'refundId', 'cancelInitiated',
                'trackingNumber', 'trackingUrl', 'carrier', 'shipped', 'shippedAt',
                'delivered', 'deliveredAt', 'shippingCost',
                'sellerPaidOut', 'sellerPaidOutAt', 'sellerPayoutTransferId',
                'payoutInitiated', 'autoReleaseBlocked', 'autoReleaseWarned',
                'autoReleaseWarningAt', 'autoReleaseWarningTimestamp',
                'autoReleasedAt', 'autoReleaseCompleted'
            ]))
        // Buyer can leave a review or seller rating on a delivered order they purchased
        || (request.auth != null
            && resource.data.buyerId == request.auth.uid
            && resource.data.delivered == true
            && resource.data.cancelled != true
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                'review', 'sellerRating', 'updatedAt'
            ]))
        // Buyer can flag a refund request or dispute on an active (not yet delivered, not cancelled) order
        || (request.auth != null
            && resource.data.buyerId == request.auth.uid
            && resource.data.sold == true
            && resource.data.cancelled != true
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                'refundRequested', 'refundRequestedAt', 'refundReason',
                'disputeOpened', 'updatedAt'
            ]));
      // Sellers can delete their own unsold listings; sold listings are locked (active order in flight)
      allow delete: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid && resource.data.sold != true);
    }

    // Users collection
    // Full doc (incl. stripeAccountId, penalties, isAdmin) only visible to owner + admins.
    // Other authenticated users get read access for public seller profiles — Firestore
    // doesn't support field-level restrictions, so keep sensitive fields off this doc
    // long-term (move to a private subcollection). For now the exposure is low-risk:
    // stripeAccountId is not a secret, and isAdmin/penalty fields are informational only.
    match /users/{userId} {
      allow read: if isAdmin()
        || (request.auth != null && request.auth.uid == userId)
        || request.auth != null;
      // New users can create their own profile document
      allow create: if request.auth != null && request.auth.uid == userId;
      // Admins can update anything; regular users can update their own doc
      // but cannot touch penalty/suspension/privilege fields
      allow update: if isAdmin()
        || (request.auth != null
          && request.auth.uid == userId
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
              'sellerSuspended', 'sellerCancellationCount', 'sellerPenalties', 'isAdmin',
              'stripeAccountId', 'stripeCreatedAt'
          ]));
      allow delete: if isAdmin();
    }

    // Usernames collection (for username uniqueness)
    match /usernames/{username} {
      allow read: if true;
      // Create: only if no document exists yet (prevents overwriting someone else's username)
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && !exists(/databases/$(database)/documents/usernames/$(username));
      // Update: only the current owner can change their own reservation
      allow update: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && resource.data.userId == request.auth.uid;
      // Delete: only the owner can release their username; Cloud Functions handle this via Admin SDK
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Orders collection
    // All order mutations (status, tracking, fulfilment, cancellation) are handled
    // exclusively by Cloud Functions via Admin SDK, which bypasses these rules.
    // Client-side update is intentionally denied — if direct client writes are ever
    // needed, add explicit field allowlists here rather than opening it broadly.
    match /orders/{orderId} {
      // Admins can read/write any order; buyers and sellers can access their own
      allow read: if isAdmin() || (request.auth != null && (
        resource.data.buyerId == request.auth.uid ||
        resource.data.sellerId == request.auth.uid
      ));
      // Only the buyer can create an order for themselves
      allow create: if request.auth != null && request.resource.data.buyerId == request.auth.uid;
      // No client-side updates — all order mutations go through Cloud Functions
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Conversations collection (messaging)
    // participants array contains [buyerId, sellerId] — enables array-contains queries
    match /conversations/{conversationId} {
      allow read: if isAdmin()
        || (request.auth != null && request.auth.uid in resource.data.participants);
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.buyerId == request.auth.uid;
      // Participants can only update messaging metadata — never structural fields like
      // participants, sellerId, productId, etc.
      allow update: if request.auth != null
        && request.auth.uid in resource.data.participants
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'lastMessage', 'lastMessageAt', 'lastSenderId',
            'unreadBuyer', 'unreadSeller', 'deletedBy'
        ]);

      match /messages/{messageId} {
        allow read: if isAdmin()
          || (request.auth != null
            && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants);
        allow write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
      }
    }

    // Watchlists — only owner can read/write
    match /watchlists/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Seller ratings — anyone can read; only verified buyers can create a review,
    // and only for products they actually purchased and that have been delivered.
    // ratingId must be {orderId}_{buyerUid} — enforced here to prevent duplicate reviews
    // (a second create attempt uses the same deterministic ID, which Firestore rejects as an update)
    match /sellerRatings/{ratingId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.buyerId
        && ratingId == request.resource.data.orderId + '_' + request.auth.uid
        && get(/databases/$(database)/documents/products/$(request.resource.data.orderId)).data.buyerId == request.auth.uid
        && get(/databases/$(database)/documents/products/$(request.resource.data.orderId)).data.delivered == true;
      allow update, delete: if isAdmin();
    }

    // Community reports — authenticated users can file a report,
    // only admins can read or manage reports
    match /reports/{reportId} {
      allow create: if request.auth != null;
      allow read, update, delete: if isAdmin();
    }

    // Refund requests — buyers can create for their own orders only, buyer or seller can read their own,
    // admins can read and update all
    match /refundRequests/{requestId} {
      allow create: if request.auth != null
        && request.resource.data.buyerId == request.auth.uid;
      allow read: if isAdmin()
        || (request.auth != null && (
          resource.data.buyerId == request.auth.uid ||
          resource.data.sellerId == request.auth.uid
        ));
      allow update: if isAdmin();
    }

    // Platform config (announcements, site settings) — anyone can read,
    // only admins can write
    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // In-app notifications — recipient can read; Cloud Functions write via Admin SDK
    // Users can update only the 'read' field on their own notifications
    match /notifications/{userId}/items/{notifId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create, delete: if false;
    }

    // Disputes — buyers can create for their own orders, buyer/seller can read their own
    match /disputes/{disputeId} {
      allow create: if request.auth != null
        && request.resource.data.buyerId == request.auth.uid;
      allow read: if isAdmin()
        || (request.auth != null && (
          resource.data.buyerId == request.auth.uid ||
          resource.data.sellerId == request.auth.uid
        ));
      allow update, delete: if isAdmin();
    }

    // Abandoned carts — written exclusively by Cloud Functions via Admin SDK; clients denied
    match /abandonedCarts/{docId} {
      allow read, write: if false;
    }

    // Rate limit counters — written only by Cloud Functions via Admin SDK, never by clients
    match /rateLimits/{userId} {
      allow read, write: if false;
    }

    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
