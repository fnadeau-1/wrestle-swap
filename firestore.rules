rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Products collection
    match /products/{productId} {
      // Anyone can read products
      allow read: if true;
      // Any signed-in user can create a product, unless they are suspended
      allow create: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('sellerSuspended', false) == false;
      // Only the owner can update or delete. sold/cancelled/buyerId set by Cloud Functions via Admin SDK.
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Users collection
    match /users/{userId} {
      // Anyone can read the public parts of a user profile (display name, ratings, etc.)
      // Only the user themselves can read sensitive fields — enforced by restricting full doc reads
      allow read: if request.auth != null && request.auth.uid == userId
        || resource.data.keys().hasOnly(['displayName', 'username', 'photoURL', 'createdAt', 'email']);
      // Users can write to their own doc, but cannot touch penalty/suspension fields
      // Those are set exclusively by Cloud Functions (Admin SDK bypasses rules)
      allow write: if request.auth != null
        && request.auth.uid == userId
        && !('sellerSuspended' in request.resource.data.diff(resource.data).affectedKeys())
        && !('sellerCancellationCount' in request.resource.data.diff(resource.data).affectedKeys())
        && !('sellerPenalties' in request.resource.data.diff(resource.data).affectedKeys());
    }

    // Usernames collection (for username uniqueness)
    match /usernames/{username} {
      allow read: if true;
      // Only the user whose ID matches the document's userId field can write
      allow write: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // Orders collection
    match /orders/{orderId} {
      // Only the buyer or seller can read their own order
      allow read: if request.auth != null && (
        resource.data.buyerId == request.auth.uid ||
        resource.data.sellerId == request.auth.uid
      );
      // Only the buyer can create an order for themselves
      allow create: if request.auth != null && request.resource.data.buyerId == request.auth.uid;
      // Only the buyer or seller can update their order
      allow update: if request.auth != null && (
        resource.data.buyerId == request.auth.uid ||
        resource.data.sellerId == request.auth.uid
      );
    }

    // Conversations collection (messaging)
    // participants array contains [buyerId, sellerId] — enables array-contains queries
    match /conversations/{conversationId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.buyerId == request.auth.uid;
      allow update: if request.auth != null
        && request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
      }
    }

    // Watchlists — only owner can read/write
    match /watchlists/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
