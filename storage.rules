rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Product images — anyone can view, only the owning user can upload
    match /product-images/{userId}/{imageId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024   // 10 MB max
        && request.resource.contentType.matches('image/.*');
    }

    // User avatars — anyone can view, only the owning user can upload
    match /user-avatars/{userId}/{imageId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024    // 5 MB max
        && request.resource.contentType.matches('image/.*');
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
